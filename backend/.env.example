PORT=5000
NODE_ENV=development

# --- Base locale (MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shoolapp
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# --- Vercel + Neon (PostgreSQL) — prioritaire si défini ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# POSTGRES_URL=   # alias fourni par l'intégration Vercel Storage

# SKIP_DB_MIGRATION=1   # (prod MySQL) désactive la migration auto au démarrage

JWT_SECRET=votre_secret_jwt_tres_long_et_securise
JWT_EXPIRES_IN=12h
ADMIN_COOKIE_NAME=sa_admin
CORS_ORIGIN=http://localhost:3001
JSON_BODY_LIMIT=200kb
UPLOAD_PATH=./uploads

# Notifications email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

NOTIFY_TEAM_EMAILS=admissions.abidjan@figs-education.com,info.abidjan@figs-education.com

# Notifications WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=
WHATSAPP_TEAM_TO=2250757688519,2250777552815
